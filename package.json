{
  "name": "tabata-timer",
  "productName": "Tabata Timer",
  "version": "1.0.0",
  "description": "Simple Tabata interval timer desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true,
        "name": "Tabata Timer"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "TabataTimer",
            "authors": "fabiocano894",
            "description": "Simple Tabata interval timer desktop app"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "win32"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "electron": "^41.2.2"
  }
}
